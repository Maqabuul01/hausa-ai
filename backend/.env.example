# Database
DATABASE_URL=sqlite:///./hausa_ai.db
# For PostgreSQL: postgresql://user:password@localhost:5432/hausa_ai

# JWT
SECRET_KEY=your-super-secret-key-change-in-production-2024
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-pro

# Environment
ENVIRONMENT=development
DEBUG=True
SQL_ECHO=False

# Server
HOST=0.0.0.0
PORT=8000
